{
  "name": {
    "en": "Wallbox",
    "de": "Wallbox"
  },
  "class": "evcharger",
  "capabilities": [
    "measure_power",
    "meter_power",
    "wallbox_charging",
    "wallbox_sun_mode",
    "measure_wallbox_solarshare"
  ],
  "capabilitiesOptions": {
    "wallbox_charging": {
      "preventInsights": true,
      "preventTag": true
    },
    "wallbox_sun_mode": {
      "preventInsights": true,
      "preventTag": true
    }
  },
  "energy": {
    "evCharger": true,
    "meterPowerImportedCapability": "meter_power"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "list_my_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_my_devices"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_my_devices",
      "template": "add_devices"
    }
  ]
}