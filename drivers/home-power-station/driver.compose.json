{
  "name": {
    "en": "HPS",
    "de": "HKW"
  },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "meter_power",
    "measure_grid_delivery",
    "measure_battery_delivery",
    "measure_house_consumption",
    "measure_battery",
    "firmware_version",
    "charge_time",
    "diagnostic_report"
  ],
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "capabilitiesOptions": {
    "measure_power": {
      "title": {
        "en": "PV power",
        "de": "PV Leistung"
      }
    },
    "meter_power": {
      "title": {
        "en": "PV generation (total)",
        "de": "PV-Erzeugung (gesamt)"
      }
    },
    "diagnostic_report": {
      "preventInsights": true,
      "preventTag": true
    }
  },
  "energy": {
    "batteries": [
      "INTERNAL"
    ],
    "meterPowerExportedCapability": "meter_power"
  },
  "pair": [
    {
      "id": "connect",
      "navigation": {
        "next": "list_my_devices"
      }
    },
    {
      "id": "list_my_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_my_devices",
        "prev": "connect"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_my_devices",
      "template": "add_devices"
    }
  ]
}
